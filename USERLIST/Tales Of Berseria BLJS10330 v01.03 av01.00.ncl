/*
Dump Location = 0x01E8F000

0001 = ^
0002 = \/
0004 = <
0008 = >
0010 = Triangle
0020 = X
0040 = []
0080 = O
0100 = Select
0200 = Start
0400 = L1
0800 = L2
1000 = L3
2000 = R1
4000 = R2
8000 = R3
*/
